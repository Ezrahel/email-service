# ── Rails ────────────────────────────────────────────────────
RAILS_ENV=development
PORT=3000
SECRET_KEY_BASE=

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@db:5432/email_service_development
DATABASE_URL_TEST=postgres://postgres:postgres@db:5432/email_service_test

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_SIDEKIQ_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
REDIS_STREAMS_URL=redis://redis:6379/3

# ── Sidekiq ──────────────────────────────────────────────────
SIDEKIQ_CONCURRENCY=10
SIDEKIQ_QUEUES=default,providers,events,webhooks,analytics,domains

# ── Authentication ───────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=604800
API_KEY_PREFIX=em_

# ── Email Providers ──────────────────────────────────────────
# Amazon SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_CONFIGURATION_SET=default

# SendGrid
SENDGRID_API_KEY=

# Mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_REGION=us

# Postmark
POSTMARK_API_KEY=
POSTMARK_ACCOUNT_TOKEN=

# SMTP Fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_DOMAIN=

# ── S3 Storage ───────────────────────────────────────────────
S3_BUCKET=email-service-storage
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER=otlp
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=email-service
SENTRY_DSN=

# ── DNS Verification ─────────────────────────────────────────
DNS_VERIFICATION_TIMEOUT=30
DNS_VERIFICATION_RETRIES=3

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_EMAILS_PER_SECOND=50
RATE_LIMIT_EMAILS_PER_DAY=10000
RATE_LIMIT_API_REQUESTS_PER_MINUTE=300

# ── Encryption ───────────────────────────────────────────────
LOCKBOX_MASTER_KEY=
